# Application Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/meteora"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Data Output
DATA_DIR=./data

# Logging
LOG_LEVEL=info
LOKI_URL=http://localhost:3100

# Metrics
METRICS_PORT=9091

# Tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=meteora-pipeline

# API Configuration
API_RETRY_ATTEMPTS=5
API_RETRY_BASE_DELAY=300
API_REQUEST_TIMEOUT=30000
API_PAGE_SIZE=50

# Alerting (Optional)
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# Feature Flags
ENABLE_DATABASE_PERSISTENCE=true
ENABLE_TRACING=true
ENABLE_LOKI_LOGGING=false

