    "zod": "^3.22.2",
    "dotenv": "^16.3.1",
    "winston": "^3.9.0",
    "prom-client": "^15.1.0",
    "@prisma/client": "^5.11.0",
    "pg": "^8.11.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.0",
    "@opentelemetry/auto-instrumentations-node": "^0.39.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.45.0",
    "winston-loki": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0",
    "vitest": "^1.0.4",
    "@types/jest": "^29.5.8",
    "prisma": "^7.8.0",
    "semantic-release": "^21.0.0"
  }
