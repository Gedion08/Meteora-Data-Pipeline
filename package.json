{
  "name": "meteora-data-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "pipeline": "npm run build && npm run start",
    "test": "vitest --run",
    "test:watch": "vitest",
    "benchmark": "ts-node tests/benchmark.ts",
